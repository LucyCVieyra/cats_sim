    <!-- Mission 1. Enter the room -->
    <!-- Takeoff Platform -->
    <model name='TakeOff Platform'>
      <static>true</static>
      <pose>0 0 0.05 1.57079 0 1.57079</pose> <!-- Initial Position +3.75 -3-->
      <link name='base_TO_platform'>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 1 0</normal>
              <size>1 1</size>
            </plane>
          </geometry>
          <material>
            <pbr>
              <metal>
                <emissive_map>model://images/Landing_Platform.png</emissive_map>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
    </model>

    <model name="tunel1_ventana1">
      <static>true</static>

      <!-- Base vertical bar -->
      <link name="base">
        <pose>1.25 -0.75 0.5 0 0 0</pose> <!-- Height is 1.0 m, so origin at 0.5 -->
        <visual name="vertical_support">
          <geometry>
            <cylinder>
              <radius>0.025</radius>
              <length>1.0</length>
            </cylinder>
          </geometry>
          <material><diffuse>0.02 0.55 1 1</diffuse></material>
        </visual>
        <!--
        <collision name="vertical_support_collision">
          <geometry>
