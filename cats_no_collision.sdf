<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <world name='indoor'>

    <!-- Physics -->
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>

    <!-- Plugins -->
    <plugin name='gz::sim::systems::Physics' filename='gz-sim-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands' filename='gz-sim-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='gz-sim-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact' filename='gz-sim-contact-system'/>
    <plugin name='gz::sim::systems::Imu' filename='gz-sim-imu-system'/>
    <plugin name='gz::sim::systems::AirPressure' filename='gz-sim-air-pressure-system'/>
    <plugin name='gz::sim::systems::Sensors' filename='gz-sim-sensors-system'>
      <render_engine>ogre2</render_engine>
    </plugin>

    <gui fullscreen='false'>
      <plugin name='3D View' filename='GzScene3D'>
        <gz-gui>
          <title>3D View</title>
          <property type='bool' key='showTitleBar'>0</property>
          <property type='string' key='state'>docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.5984631152222222 0.5984631152222222 0.5984631152222222</ambient_light>
        <background_color>0.8984631152222222 0.8984631152222222 0.8984631152222222</background_color>
        <camera_pose>-6 0 6 0 0.5 0</camera_pose>
      </plugin>
      <plugin name='World control' filename='WorldControl'>
        <gz-gui>
          <title>World control</title>
          <property type='bool' key='showTitleBar'>0</property>
          <property type='bool' key='resizable'>0</property>
          <property type='double' key='height'>72</property>
          <property type='double' key='width'>121</property>
          <property type='double' key='z'>1</property>
          <property type='string' key='state'>floating</property>
          <anchors target='3D View'>
            <line own='left' target='left'/>
            <line own='bottom' target='bottom'/>
          </anchors>
        </gz-gui>
        <play_pause>1</play_pause>
        <step>1</step>
        <start_paused>false</start_paused>
      </plugin>
      <plugin name='World stats' filename='WorldStats'>
        <gz-gui>
          <title>World stats</title>
          <property type='bool' key='showTitleBar'>0</property>
          <property type='bool' key='resizable'>0</property>
          <property type='double' key='height'>110</property>
          <property type='double' key='width'>290</property>
          <property type='double' key='z'>1</property>
          <property type='string' key='state'>floating</property>
          <anchors target='3D View'>
            <line own='right' target='right'/>
            <line own='bottom' target='bottom'/>
          </anchors>
        </gz-gui>
        <sim_time>1</sim_time>
        <real_time>1</real_time>
        <real_time_factor>1</real_time_factor>
        <iterations>1</iterations>
      </plugin>
      <plugin name='Entity tree' filename='EntityTree'/>
    </gui>

    <!-- Environment -->
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type='adiabatic'/>
    <scene>
      <grid>false</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- Ground plane -->
    <model name='ground_plane'>
      <static>true</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <surface>
            <friction><ode/></friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name='visual'>
        <pose>0 0 0 1.5708 0 0</pose>
          <geometry>
            <mesh>
              <uri>file://meshes/floor_1.glb</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
      </link>
    </model>

    <!-- Lights -->
    <light name='sunUTC' type='directional'>
      <pose>0 0 500 0 0 0</pose> <!-- Posición de la luz, la orientación no es relevante para luz direccional -->
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>0 0 -1</direction> <!-- Dirección completamente vertical hacia abajo -->
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>0.271 0.271 0.271 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

    <light name='directional_light1' type='directional'>
      <pose>500 0 500 0 0 0</pose> 
      <direction>-1 0 -1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>
    
    <light name='directional_light2' type='directional'>
      <pose>0 500 500 0 0 0</pose> 
      <direction>0 -1 -1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>

    <light name='directional_light3' type='directional'>
      <pose>-500 0 500 0 0 0</pose> 
      <direction>-1 0 -1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>
    
    <light name='directional_light4' type='directional'>
      <pose>0 -500 500 0 0 0</pose> 
      <direction>0 -1 -1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>

    <light name='directional_light5' type='directional'>
      <pose>500 0 500 0 0 0</pose> 
      <direction>1 0 1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>
    
    <light name='directional_light6' type='directional'>
      <pose>0 500 500 0 0 0</pose> 
      <direction>0 1 1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>

    <light name='directional_light7' type='directional'>
      <pose>-500 0 500 0 0 0</pose> 
      <direction>1 0 1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>
    
    <light name='directional_light8' type='directional'>
      <pose>0 -500 500 0 0 0</pose> 
      <direction>0 1 1</direction>
      <intensity>0.5</intensity>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.5 0.5 0.5 1</specular>
    </light>

    <!-- Walls -->   
    <model name="back_wall">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10 0.1 7</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <mesh>
              <uri>meshes/piedra_ladrillo_wall_3.glb</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
        <pose>3.75 -8 0 1.57079 0 0</pose>
      </link>
    </model>

    <model name="front_wall">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10 0.1 7</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <mesh>
              <uri>meshes/white_wall_3.glb</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
        <pose>3.75 2 0 1.5707 0 0</pose>
      </link>
    </model>

    <model name="left_wall">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10 0.1 7</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <pose>0 0 -1.25 1.5708 0 0</pose>
          <geometry>
            <mesh>
              <uri>meshes/grafiti_wall_3.glb</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
        <pose>-5 0 1.25 0 0 1.5708</pose>
      </link>
      <pose>3.75 -3 0 0 0 0</pose>
    </model>

    <model name="right_wall">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.1 10 7</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <pose>0 0 -1.25 1.5708 0 1.5708</pose>
          <geometry>
            <mesh>
              <uri>meshes/ladrillo_irregular_wall_3.glb</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
        <pose>8.75 -3 1.25 0 0 0</pose>
      </link>
    </model>

    <!-- Obstacles -->
    <model name="obstacle_1">
      <static>true</static>
      <pose>7.5 0.5 2.5 0 0 0</pose> <!-- x, y, z, roll, pitch, yaw -->
      <link name="obstacle_link">
        <visual name="obstacle_visual">
          <geometry>
            <cylinder>
              <radius>0.15</radius>   <!-- 30 cm diameter -->
              <length>5</length>    <!-- 50 cm tall -->
            </cylinder>
          </geometry>
          <material>
            <diffuse>0.35 0.43 0.15 1</diffuse> <!-- Gray -->
          </material>
        </visual>
        <!--
        <collision name="obstacle_collision">
